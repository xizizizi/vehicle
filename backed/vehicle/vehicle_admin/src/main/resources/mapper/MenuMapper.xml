<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="io.vehicle.vehicle_admin.mapper.MenuMapper">

    <resultMap id="menuMap" type="io.vehicle.vehicle_admin.entity.Menu">
        <id column="menu_id" property="menuId"/>
        <result column="name" property="name"/>
        <result column="redirect" property="redirect"/>
        <result column="path" property="path"/>
        <result column="component" property="component"/>
        <result column="meta" typeHandler="io.vehicle.vehicle_admin.handler.MetaTypeHandler"/>
        <result column="parent_id" property="parentId"/>
        <collection property="children" column="menu_id"
                    select="io.vehicle.vehicle_admin.mapper.MenuMapper.getSubMenuList"/>
    </resultMap>

    <select id="getMenuTree" resultMap="menuMap">
        SELECT * FROM menu WHERE parent_id = 0
    </select>

    <select id="getSubMenuList" resultMap="menuMap" parameterType="int">
        SELECT * FROM menu WHERE parent_id =#{menuId}
    </select>
</mapper>